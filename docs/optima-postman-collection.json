{
  "info": {
    "name": "Optima Backend API",
    "description": "Colección de pruebas del backend Optima (TFG DAM Spring Boot 3.4.1 / Java 21).\n\nVariables de colección:\n- baseUrl: http://localhost:8080\n- businessId, userId, taxId, hourId, scheduleId, absenceId, clientId, categoryId, serviceId, appointmentId, slug\n\nOrden recomendado de pruebas:\n1) auth → token\n2) business → POST (guardar id en businessId)\n3) roles → GET (anota un roleId)\n4) users → POST (con roleId)\n5) taxes → POST\n6) categories → POST\n7) services → POST (usa categoryId y taxId)\n8) clients → POST\n9) hours → POST (uno por día de la semana)\n10) schedules → POST (horario del empleado)\n11) appointments → POST (con clientId, employeeId, serviceIds)\n12) appointments → PATCH /status para cambiar a CONFIRMED, etc.\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "auth",
      "description": "Autenticación. POST /api/auth/token devuelve un JWT.",
      "item": [
        {
          "name": "POST · login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "token"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@optima.com\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Devuelve un token JWT. Hoy compara contra credenciales hardcoded (admin@optima.com / 123456)."
          }
        }
      ]
    },
